[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "今日もまた悪いわね、クレオ。\n座学の邪魔になっちゃってるかしら？",
		"voice_file": "VOICE_MAIN_002_037_01205",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "ううん！　むしろ気分転換になって助かってるかも！",
		"voice_file": "VOICE_MAIN_234_037_01206",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "それよりも、早い再訪で驚いたよ。\nもう他の兄弟たちとの話は済んだの？",
		"voice_file": "VOICE_MAIN_234_037_01207",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええ！　みんなから色々話を聞いて、\nヘルトのことをこれまで以上に理解できたと思う",
		"voice_file": "VOICE_MAIN_002_037_01208",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "それで改めて、ヘルトと一番親しいゼロの話を\n聞きに来たの。二人で話してもいいかしら？",
		"voice_file": "VOICE_MAIN_002_037_01209",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "兵は外に待機させておくから、\n兄弟水入らず、話しておいで！",
		"voice_file": "VOICE_MAIN_234_037_01210",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "――でな、兄者の天才的な作戦と我の超最強の力を\n合わせることにより、見事竜を討ち取ったんじゃ！！",
		"voice_file": "VOICE_MAIN_228_037_01211",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者と我だからこそ成し遂げられたのじゃ！\nどうじゃ？　すごいじゃろう！！",
		"voice_file": "VOICE_MAIN_228_037_01212",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "そ、そりゃ、確かにすごいわね",
		"voice_file": "VOICE_MAIN_002_037_01213",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（ゼロの話、止まらないわ……話始めてから\n　もうかれこれ２時間くらい過ぎてるわよね……）",
		"voice_file": "VOICE_MAIN_002_037_01214",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（でもそれくらい、ゼロには\n　ヘルトとの思い出があるってことよね）",
		"voice_file": "VOICE_MAIN_002_037_01215",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "やっぱり二人って、すっごく仲がいいのね。\nゼロにとって、ヘルトはいいお兄ちゃんなのね",
		"voice_file": "VOICE_MAIN_002_037_01216",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "そうでもあるが、そうでもない！！！",
		"voice_file": "VOICE_MAIN_228_037_01217",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "どっち！？",
		"voice_file": "VOICE_MAIN_002_037_01218",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者のせいで……兄者がいるから、\n我は真なる最強になれないのじゃ！！",
		"voice_file": "VOICE_MAIN_228_037_01219",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "腕相撲で勝っても頭脳を絡めた実戦となると厳しい！　\n我は最強なのに！　ゼロなのに！！",
		"voice_file": "VOICE_MAIN_228_037_01220",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "な、なるほど、戦士としては複雑なのね",
		"voice_file": "VOICE_MAIN_002_037_01221",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ああ……たくさん声を出したから、\n身体が空腹を訴えておる！",
		"voice_file": "VOICE_MAIN_228_037_01222",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者の作る飯が食べたいのぉ……\nあの、温かくてうまいやつ……",
		"voice_file": "VOICE_MAIN_228_037_01223",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ヘルトの料理……それってどんなの？",
		"voice_file": "VOICE_MAIN_002_037_01224",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "うまい汁にうまい肉とうまい芋が入っておるんじゃ。\n我はあれが一等好きでのぉ",
		"voice_file": "VOICE_MAIN_228_037_01225",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "へぇ……スープ的なものかしら。\nヘルトがよく作ってくれたの？",
		"voice_file": "VOICE_MAIN_002_037_01226",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "そうじゃ。よく作っていたからの、\nきっと兄者自身も好きなんじゃ",
		"voice_file": "VOICE_MAIN_228_037_01227",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ふーん……",
		"voice_file": "VOICE_MAIN_002_037_01228",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ねぇゼロ。そのスープ、食べたいんでしょ？\nなら、私が作ってあげる！",
		"voice_file": "VOICE_MAIN_002_037_01229",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "ヴァレリアがか……？　丸焼きしか知らぬうぬに\n兄者のスープが作れるのか？",
		"voice_file": "VOICE_MAIN_228_037_01230",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "つ、作れるわよ！　きっと",
		"voice_file": "VOICE_MAIN_002_037_01231",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（ヘルトがよく作っていたなら、\n　他の兄弟たちも知っている料理かもしれないし）",
		"voice_file": "VOICE_MAIN_002_037_01232",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（好きなスープなら、今のヘルトでも\n　美味しく食べてもらえるかもしれない）",
		"voice_file": "VOICE_MAIN_002_037_01233",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "決めた！\nそのスープで、第２回九偉人会を開催するわ！",
		"voice_file": "VOICE_MAIN_002_037_01234",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "はーっ。お前本当に自分で動くようになったのう",
		"voice_file": "VOICE_MAIN_228_037_01235",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	}
]