[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "じゃあみんな、片付けを始めるわよー",
		"voice_file": "VOICE_MAIN_002_037_01406",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "昨日の夜は片付けって雰囲気じゃなかったけど……\n日を置くとより面倒に感じちゃうわね",
		"voice_file": "VOICE_MAIN_002_037_01407",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "あはは、そうだね。長引くとよりめんどくさくなるから\nちゃちゃっと終わらせちゃおう",
		"voice_file": "VOICE_MAIN_153_037_01408",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "はーい",
		"voice_file": "VOICE_MAIN_002_037_01409",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "よし、ここの片付けは終わりね！\nなんか、前より片付いてる気がするわね",
		"voice_file": "VOICE_MAIN_002_037_01410",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "当然です。片付けは、\nただ以前の形に戻すのみではありません",
		"voice_file": "VOICE_MAIN_156_037_01411",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "僕、疲れたよー。\nヴァレリア、お茶淹れてくれない？",
		"voice_file": "VOICE_MAIN_154_037_01412",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "私が淹れましょう！　ナナたちも飲みたいだろう？\nみんなで一服しよう！",
		"voice_file": "VOICE_MAIN_155_037_01413",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ありがとう！　そうね、\nみんなで向こうで飲みましょっか",
		"voice_file": "VOICE_MAIN_002_037_01414",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "……あ、あ！　ああ！！",
		"voice_file": "VOICE_MAIN_228_037_01415",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "ゼロ姉貴、どうし――ああっ！！",
		"voice_file": "VOICE_MAIN_200_037_01416",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "二人とも？　なに――",
		"voice_file": "VOICE_MAIN_002_037_01417",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "間抜け面をさらすな。弱く見える",
		"voice_file": "VOICE_MAIN_227_037_01418",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "兄者あああーーー！！！",
		"voice_file": "VOICE_MAIN_228_037_01419",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "兄貴！　元気になったんだね！",
		"voice_file": "VOICE_MAIN_200_037_01420",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "心配したよ、ヘル兄。\nもう気分は大丈夫なのかい？",
		"voice_file": "VOICE_MAIN_153_037_01421",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ああ。問題ない",
		"voice_file": "VOICE_MAIN_227_037_01422",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "私たち兄弟の絆ですね、兄様！",
		"voice_file": "VOICE_MAIN_155_037_01423",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "僕たちを振り回して、腹が立つんだけど？\nというか、まだスープの感想聞いてないよねぇ？",
		"voice_file": "VOICE_MAIN_154_037_01424",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ああ、あのスープ、お前たちが作ったんだったな",
		"voice_file": "VOICE_MAIN_227_037_01425",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "うまかった。さすが、俺のレシピだ",
		"voice_file": "VOICE_MAIN_227_037_01426",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "うむ、さすが兄者じゃあ！",
		"voice_file": "VOICE_MAIN_228_037_01427",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "あっはは！　もうすっかりいつも通りみたいだね",
		"voice_file": "VOICE_MAIN_153_037_01428",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "もう……ほんと、心配したんだから。\n元気になってよかったわ",
		"voice_file": "VOICE_MAIN_002_037_01429",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "……ふん",
		"voice_file": "VOICE_MAIN_227_037_01430",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "お前らが果ての大陸へ向かうため、\n俺も力を貸してやろう",
		"voice_file": "VOICE_MAIN_227_037_01431",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "「貸してやろう」……？",
		"voice_file": "VOICE_MAIN_154_037_01432",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "シトリン、なんか言ったか",
		"voice_file": "VOICE_MAIN_227_037_01433",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "いっ、いや、ナニモ……",
		"voice_file": "VOICE_MAIN_154_037_01434",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ビビるなら言わなきゃいいのにねぇ。\nまぁ、少しずつ免疫をつけてくこった",
		"voice_file": "VOICE_MAIN_153_037_01435",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ヘルト、力を貸してくれるのは嬉しいんだけど……\nそれって、私たちに負けたから……？",
		"voice_file": "VOICE_MAIN_002_037_01436",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "……はっ、戯言を",
		"voice_file": "VOICE_MAIN_227_037_01437",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "俺はお前らの兄として、\n俺がやるべきことをやるだけだ",
		"voice_file": "VOICE_MAIN_227_037_01438",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "お前らにはまだまだ\n長兄である俺の存在が必要みたいだからな",
		"voice_file": "VOICE_MAIN_227_037_01439",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "……ふふ、そっか。\n改めてこれからよろしくね、ヘルト！",
		"voice_file": "VOICE_MAIN_002_037_01440",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "俺を失望させるなよ。\n俺がいるからには、敗北も失敗も許さん",
		"voice_file": "VOICE_MAIN_227_037_01441",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええ！　成長した私たちの姿、見せてあげる！",
		"voice_file": "VOICE_MAIN_002_037_01442",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "これで、九偉人全員が揃ったね！",
		"voice_file": "VOICE_MAIN_200_037_01443",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "私たちに課せられた使命、果たす時は近い",
		"voice_file": "VOICE_MAIN_199_037_01444",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "ナナは安心して、兄弟に頼るといい！\n全力で手助けしよう！",
		"voice_file": "VOICE_MAIN_155_037_01445",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "パルメ族がなぜレスナやお前さんを果ての大陸へ\n行かせたがるのか。その真意も行けば分かるさ",
		"voice_file": "VOICE_MAIN_153_037_01446",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "暗黒の氷海……あそこの魔物は\n戦い甲斐がある。腕が鳴るのぉ！",
		"voice_file": "VOICE_MAIN_228_037_01447",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 42,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "うん、みんながいてくれたら心強いわ。\n果ての大陸まで、よろしくね！",
		"voice_file": "VOICE_MAIN_002_037_01448",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 43,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "準備ができたら連絡してください。\n私たちも用意を整えておきます",
		"voice_file": "VOICE_MAIN_156_037_01449",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 44,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "果ての大陸、言うだけあって遠かったけど……\n最果てまで、あと少しね",
		"voice_file": "VOICE_MAIN_002_037_01450",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	}
]