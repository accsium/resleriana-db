[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "みんな、なにしてるの？",
		"voice_file": "VOICE_MAIN_002_038_00652",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "ま、すぐ分かるよ。ヴァレリアも余ってるとこに行って",
		"voice_file": "VOICE_MAIN_154_038_00653",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "はあ……",
		"voice_file": "VOICE_MAIN_002_038_00654",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "ではこの長兄が、認証の一番手となろう",
		"voice_file": "VOICE_MAIN_227_038_00655",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "ルイネ州の機構はこの装置が破損しており、\n修復も不能で使えなかったのですが",
		"voice_file": "VOICE_MAIN_156_038_00656",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "ここのは使用可能",
		"voice_file": "VOICE_MAIN_199_038_00657",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "さあ、ナナもやってごらん",
		"voice_file": "VOICE_MAIN_155_038_00658",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "えーと……こう？",
		"voice_file": "VOICE_MAIN_002_038_00659",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "な、なにこれ……\nなんか、耳がキーンって！",
		"voice_file": "VOICE_MAIN_048_038_00660",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "これは……",
		"voice_file": "VOICE_MAIN_001_038_00661",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "そっか……これは本当に門なんだ！",
		"voice_file": "VOICE_MAIN_001_038_00662",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "レスナちゃん、大丈夫なの！？",
		"voice_file": "VOICE_MAIN_048_038_00663",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ロマン",
		"romanized_name": "Roman",
		"model_path_hash": "2044084852602675005",
		"text": "門の向こうに、入れたはずの手が見えない……！？\nこ、これは！？",
		"voice_file": "VOICE_MAIN_049_038_00664",
		"still_path_hash": "2419706081160656678",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "えっと、これはトラベルゲートみたいな転送装置です。\nどこか遠くの場所と繋がっています……多分",
		"voice_file": "VOICE_MAIN_001_038_00665",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "多分って、なんでそんなこと知ってるの？",
		"voice_file": "VOICE_MAIN_234_038_00666",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "知っているというか、なんとなく分かったっていうか。\n頭の中に門の構造とかがフッと思い浮かんで……",
		"voice_file": "VOICE_MAIN_001_038_00667",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "本当に大丈夫なの？　……なーんて、\nいちいち聞かないよ。レスナちゃんのことだし",
		"voice_file": "VOICE_MAIN_048_038_00668",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "ええ。行きましょう、門の先へ",
		"voice_file": "VOICE_MAIN_004_038_00669",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "……うんっ！　では、いざゆかん！",
		"voice_file": "VOICE_MAIN_001_038_00670",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "ゆかーん！",
		"voice_file": "VOICE_MAIN_048_038_00671",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	}
]