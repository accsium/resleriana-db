[
	{
		"id": 0,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "ランツェさんの演説聞きたかったなぁ。\nあの人も航海で大変な目にあってたなんて",
		"voice_file": "VOICE_MAIN_150_038_00335",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "姉様の気持ちを分かってくれる人だった……",
		"voice_file": "VOICE_MAIN_151_038_00336",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "ランツェさんはフロッケ号で、私たちはバーバラ号。\nその前はアルビ号だったからなかなか話す機会がね……",
		"voice_file": "VOICE_MAIN_152_038_00337",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "……男は自分の失敗を\n他人にあまり話さないものさ",
		"voice_file": "VOICE_MAIN_223_038_00338",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "別に、男に限らないと思うけど",
		"voice_file": "VOICE_MAIN_151_038_00339",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "……まあ、そういう説もある",
		"voice_file": "VOICE_MAIN_223_038_00340",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ユミア",
		"romanized_name": "Yumia",
		"model_path_hash": "8553801663070209956",
		"text": "ジョゼさん、ぜんぜん釣れてないですね",
		"voice_file": "VOICE_MAIN_164_038_00341",
		"still_path_hash": "3603268135404135156",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "海の魚は気まぐれなのさ。\nじっくりと向き合って、ようやく微笑んでくれる",
		"voice_file": "VOICE_MAIN_223_038_00342",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "魚釣り、そんなに難しくない",
		"voice_file": "VOICE_MAIN_151_038_00343",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "だったら勝負してみるかい？　もし嬢ちゃんが\n先に釣ったら、この仮面を外してあげよう",
		"voice_file": "VOICE_MAIN_223_038_00344",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "……乗った",
		"voice_file": "VOICE_MAIN_151_038_00345",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "また変な勝負を始めて……ん？",
		"voice_file": "VOICE_MAIN_150_038_00346",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "泳いでる魚の口に向かって、針をかける……",
		"voice_file": "VOICE_MAIN_151_038_00347",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "一丁上がり",
		"voice_file": "VOICE_MAIN_151_038_00348",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "また力技な……",
		"voice_file": "VOICE_MAIN_150_038_00349",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "ベップちゃんがいれば、\n海の上でも食事の心配はないわね",
		"voice_file": "VOICE_MAIN_152_038_00350",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "参った、俺の完敗だ。\n約束通り、仮面を外そう",
		"voice_file": "VOICE_MAIN_223_038_00351",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ユミア",
		"romanized_name": "Yumia",
		"model_path_hash": "8553801663070209956",
		"text": "ええっ！？",
		"voice_file": "VOICE_MAIN_164_038_00352",
		"still_path_hash": "3603268135404135156",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "秘技・二重仮面",
		"voice_file": "VOICE_MAIN_223_038_00353",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "な、なんの意味が……",
		"voice_file": "VOICE_MAIN_151_038_00354",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "だから仮面を外すなんて条件で勝負を挑んだのね……",
		"voice_file": "VOICE_MAIN_150_038_00355",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "フッ、残念だったね",
		"voice_file": "VOICE_MAIN_223_038_00356",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "なんだか、寒くなってきちゃった",
		"voice_file": "VOICE_MAIN_152_038_00357",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "ほら、ジョゼのネタがつまらなかったから\n被害者が出てきちゃいましたよ",
		"voice_file": "VOICE_MAIN_150_038_00358",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "ユミア",
		"romanized_name": "Yumia",
		"model_path_hash": "8553801663070209956",
		"text": "被害者って……アルビーナも結構言うよね",
		"voice_file": "VOICE_MAIN_164_038_00359",
		"still_path_hash": "3603268135404135156",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "それもあるかもだけど、原因はあれかも……",
		"voice_file": "VOICE_MAIN_151_038_00360",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "流氷……オーベンランドが近いんだわ",
		"voice_file": "VOICE_MAIN_151_038_00361",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "オーベンランド……暗黒の氷海があった……",
		"voice_file": "VOICE_MAIN_150_038_00362",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "話には聞いてる……大丈夫か？\nアルビーナの嬢ちゃんは",
		"voice_file": "VOICE_MAIN_223_038_00363",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "大丈夫……そう言えるように、してきたつもり",
		"voice_file": "VOICE_MAIN_150_038_00364",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	}
]