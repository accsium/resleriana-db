[
	{
		"id": 0,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "連続して誤った回答がされました。\n処理４へ移行します",
		"voice_file": "VOICE_MAIN_723_038_00554",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "来たわね。なんだか、不気味なんだけど……",
		"voice_file": "VOICE_MAIN_004_038_00555",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "ああ……こりゃまずい",
		"voice_file": "VOICE_MAIN_051_038_00556",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "ぐっ！",
		"voice_file": "VOICE_MAIN_048_038_00557",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "なに、これ！",
		"voice_file": "VOICE_MAIN_004_038_00558",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "イザナちゃん！　ヨハナちゃん！",
		"voice_file": "VOICE_MAIN_001_038_00559",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "問３",
		"voice_file": "VOICE_MAIN_723_038_00560",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "！？",
		"voice_file": "VOICE_MAIN_001_038_00561",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "この星に危機が訪れるとします。\n人間は全滅することでしょう",
		"voice_file": "VOICE_MAIN_723_038_00562",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "しかし、あなたの力をもってすれば、\n１０００人だけ救うことができるでしょう",
		"voice_file": "VOICE_MAIN_723_038_00563",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あなたはどうしますか？",
		"voice_file": "VOICE_MAIN_723_038_00564",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "わ、私は……！",
		"voice_file": "VOICE_MAIN_001_038_00565",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "レスナ。あなたが「選択」をすれば、\nこの二人は無事解放される",
		"voice_file": "VOICE_MAIN_723_038_00566",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "さもなくば、この二人の命は、無い",
		"voice_file": "VOICE_MAIN_723_038_00567",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "あなたはどうしますか？",
		"voice_file": "VOICE_MAIN_723_038_00568",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "１０\n９\n８",
		"voice_file": "VOICE_MAIN_723_038_00569",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "まずい！　さっきの攻撃が二人に！",
		"voice_file": "VOICE_MAIN_051_038_00570",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "７\n６\n５",
		"voice_file": "VOICE_MAIN_723_038_00571",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ハイディさん、煙幕を！",
		"voice_file": "VOICE_MAIN_001_038_00572",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "了解！",
		"voice_file": "VOICE_MAIN_051_038_00573",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "４\n３\n２",
		"voice_file": "VOICE_MAIN_723_038_00574",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "１",
		"voice_file": "VOICE_MAIN_723_038_00575",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "案内人",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "０",
		"voice_file": "VOICE_MAIN_723_038_00576",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "見たことのある拘束です。\nなんの対策もしてないわけないじゃないですか",
		"voice_file": "VOICE_MAIN_001_038_00577",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "あらかじめ、拘束を解除する道具を作っていました。\nこれが錬金術の力です",
		"voice_file": "VOICE_MAIN_001_038_00578",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "これと同じことです！　何があろうと……\nどんな「選択」だって……錬金術で乗り越えてみせる！",
		"voice_file": "VOICE_MAIN_001_038_00579",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "錬金術は、みんなを幸せにする力！\n私はこの力と、可能性を信じてるんだ！！！",
		"voice_file": "VOICE_MAIN_001_038_00580",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "確かにそれだけじゃできないこともあるかもしれない。\nでも、みんながいる！",
		"voice_file": "VOICE_MAIN_001_038_00581",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "やり遂げる意志がある限りできないことなんかない！\n私は、みんなを信じてるんだ！！！",
		"voice_file": "VOICE_MAIN_001_038_00582",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "そうだよ。ずっとそばでレスナちゃんを見てきた。\nレスナちゃんがたくさんの人を救う姿を！",
		"voice_file": "VOICE_MAIN_048_038_00583",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "私もレスナに救われた。レスナはこんな私にも、\n道を、未来を、示してくれた！",
		"voice_file": "VOICE_MAIN_004_038_00584",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "そんなレスナちゃんをアタシたちは信じる！\n何が行く手を阻もうと、アタシたちが道を切り開く！",
		"voice_file": "VOICE_MAIN_048_038_00585",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "私だってヴァレリアをずっとそばで見てきた。\nこいつのすごさ、あんた知らないだろ",
		"voice_file": "VOICE_MAIN_051_038_00586",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "こいつはね、自分の命を失おうが、記憶を失おうが、\nそれでも自分の意志を貫いてきたんだ！",
		"voice_file": "VOICE_MAIN_051_038_00587",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ハイディ",
		"romanized_name": "Heidi",
		"model_path_hash": "4131218363577277631",
		"text": "その姿が色んな人を動かすことを、私は知ってる！\n意志の力、舐めんじゃないよ！！！",
		"voice_file": "VOICE_MAIN_051_038_00588",
		"still_path_hash": "5092952616707211512",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "損得なんて考え方で人を救えるとは思わない。\n私は知ってる。大切なのは、寄り添うことだと",
		"voice_file": "VOICE_MAIN_151_038_00589",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "姉様にはそれができる！\nそんな姉様を否定するというなら……斬る！！！",
		"voice_file": "VOICE_MAIN_151_038_00590",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "ありがと、ベップ。嬉しいよ",
		"voice_file": "VOICE_MAIN_150_038_00591",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "そんでね、いい加減うんざりなんすわ！\n全部余計なお節介だっつーの！",
		"voice_file": "VOICE_MAIN_150_038_00592",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "私たちの道は私たちで決める。\nそうでしょ、レスナ？",
		"voice_file": "VOICE_MAIN_002_038_00593",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 40,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん！",
		"voice_file": "VOICE_MAIN_001_038_00594",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 41,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "絶対に負けない――みんな、行くよ！！！",
		"voice_file": "VOICE_MAIN_001_038_00595",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	}
]