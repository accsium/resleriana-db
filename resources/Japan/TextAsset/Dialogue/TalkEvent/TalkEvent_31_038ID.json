[
	{
		"id": 0,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（…………）",
		"voice_file": "VOICE_MAIN_227_037_01308",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（……騒がしい）",
		"voice_file": "VOICE_MAIN_227_037_01309",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（――懐かしい香りだ）",
		"voice_file": "VOICE_MAIN_227_037_01310",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（昔、ザスキアが作ってくれたスープ……\n　あれによく似ている）",
		"voice_file": "VOICE_MAIN_227_037_01311",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（いや、似ているが違う。\n　これは、俺がゼロたちに作るスープの香りだ）",
		"voice_file": "VOICE_MAIN_227_037_01312",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（あいつらが落ち込んでいたり、くじけているとき、\n　あのスープを作ってやると喜んでいた……）",
		"voice_file": "VOICE_MAIN_227_037_01313",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（長兄として、自分がされて嬉しかったことを、\n　真似していただけなんだがな）",
		"voice_file": "VOICE_MAIN_227_037_01314",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（……もう久しく作っていない）",
		"voice_file": "VOICE_MAIN_227_037_01315",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "……ふむ、こんなものでしょう。\nゼロ姉様、味加減をご確認ください",
		"voice_file": "VOICE_MAIN_156_037_01316",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "どれどれ……ほう、うまいのう。\nこれぞ、忘れがたき兄者の味じゃ",
		"voice_file": "VOICE_MAIN_228_037_01317",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（……もう俺が、作ることもないだろう。\n　俺は敗北したのだから）",
		"voice_file": "VOICE_MAIN_227_037_01318",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（俺は、英雄などではなかった。\n　こんなところで負けてしまうようでは）",
		"voice_file": "VOICE_MAIN_227_037_01319",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（兄弟たちも、俺の導きなどなしに\n　お互いで支え合って、上手くやれている）",
		"voice_file": "VOICE_MAIN_227_037_01320",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（……兄がいなくとも、\n　こいつらはもう大丈夫なんだ……）",
		"voice_file": "VOICE_MAIN_227_037_01321",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "0",
		"text": "（……もう、すべてどうでもいい――）",
		"voice_file": "VOICE_MAIN_227_037_01322",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "よし、完成ね！\nうーん、いい匂い！",
		"voice_file": "VOICE_MAIN_002_037_01323",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "兄弟みんなの協力で完成した、兄様のスープ……！\nこんな日が来るなんて……私は嬉しいぞ……！！",
		"voice_file": "VOICE_MAIN_155_037_01324",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ちょっとゴゥ、感極まるには気が早いよ！\nほら、スープよそうから手伝っておくれ",
		"voice_file": "VOICE_MAIN_153_037_01325",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "イェルカ姉貴、手伝うよ！",
		"voice_file": "VOICE_MAIN_200_037_01326",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "では私は、食卓の準備を",
		"voice_file": "VOICE_MAIN_199_037_01327",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ありがとね！　それじゃ、ヴァレリアとシトリンは\nヘル兄を席に案内してあげとくれ！",
		"voice_file": "VOICE_MAIN_153_037_01328",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "なんで僕が……はぁ……",
		"voice_file": "VOICE_MAIN_154_037_01329",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "もう、シトリン、文句言わないで！\n兄弟みんなで協力しましょ！",
		"voice_file": "VOICE_MAIN_002_037_01330",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ヘルト、待たせたわね！\nご飯できたわよー",
		"voice_file": "VOICE_MAIN_002_037_01331",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "……はぁ、無視してくれちゃってさ、\nほんと、拍子抜けだよ",
		"voice_file": "VOICE_MAIN_154_037_01332",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "……ほら、行くよ",
		"voice_file": "VOICE_MAIN_154_037_01333",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "さ、みんなでスープを食べましょ！",
		"voice_file": "VOICE_MAIN_002_037_01334",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	}
]