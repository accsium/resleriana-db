[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "入ったわね、暗黒の氷海！",
		"voice_file": "VOICE_MAIN_002_038_00396",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "こいつは猛烈なお出迎えだね！",
		"voice_file": "VOICE_MAIN_154_038_00397",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "雪が痛いし、呼吸ができない……",
		"voice_file": "VOICE_MAIN_200_038_00398",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "なんじゃ、この程度で弱音か？\n九偉人ともあろう者が",
		"voice_file": "VOICE_MAIN_228_038_00399",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "まったくだ、吹雪などもののうちに入らんだろうに",
		"voice_file": "VOICE_MAIN_227_038_00400",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "なんでこの状況で平然としていられるのよ……",
		"voice_file": "VOICE_MAIN_002_038_00401",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "寒冷地仕様の呼吸法がある。\nそこから気を付けろ",
		"voice_file": "VOICE_MAIN_227_038_00402",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "呼吸法？　具体的には？",
		"voice_file": "VOICE_MAIN_154_038_00403",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "自分で考えろ。赤子じゃあるまい",
		"voice_file": "VOICE_MAIN_228_038_00404",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "うぅ、やっぱり厳しい……",
		"voice_file": "VOICE_MAIN_200_038_00405",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "やれやれ、いいかい？　身をかがめて\n鼻や口に雪が当たらないように……",
		"voice_file": "VOICE_MAIN_153_038_00406",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "警告、魔物が接近しています",
		"voice_file": "VOICE_MAIN_199_038_00407",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええっ！？",
		"voice_file": "VOICE_MAIN_002_038_00408",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "こんな時に！　倒さなくては……！",
		"voice_file": "VOICE_MAIN_155_038_00409",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "ですが、こうも風が強いと戦うといっても……",
		"voice_file": "VOICE_MAIN_156_038_00410",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "しょうがない、ここは英雄が守るとするか",
		"voice_file": "VOICE_MAIN_227_038_00411",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "なるほど、この環境下で生き抜いているだけはある。\nなかなかの歯応え、こうでなくてはのう！",
		"voice_file": "VOICE_MAIN_228_038_00412",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "さすが、敵にすると恐ろしい分\n味方のときは頼もしいわ",
		"voice_file": "VOICE_MAIN_002_038_00413",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "アタシたちも続くよ！",
		"voice_file": "VOICE_MAIN_153_038_00414",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "が、頑張る！",
		"voice_file": "VOICE_MAIN_200_038_00415",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	}
]