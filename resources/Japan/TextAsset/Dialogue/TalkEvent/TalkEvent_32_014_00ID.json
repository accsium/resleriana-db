[
	{
		"id": 0,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "ベップ、今だよ！",
		"voice_file": "VOICE_MAIN_150_038_00458",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "煙幕、展開！",
		"voice_file": "VOICE_MAIN_151_038_00459",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "いっけえええ！！！",
		"voice_file": "VOICE_MAIN_150_038_00460",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "よっし、作戦通り！　あっちに引き付けられてる！",
		"voice_file": "VOICE_MAIN_150_038_00461",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "撒ききれなかった魔物も、すべて倒したわ",
		"voice_file": "VOICE_MAIN_151_038_00462",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "今のうちに突っ切るよ！！",
		"voice_file": "VOICE_MAIN_150_038_00463",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "群れが、遠ざかっていく……",
		"voice_file": "VOICE_MAIN_151_038_00464",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "やった……前はダメだった所を\n今回は越せた……借りは返せた！",
		"voice_file": "VOICE_MAIN_150_038_00465",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "やるね、アルビーナの嬢ちゃん",
		"voice_file": "VOICE_MAIN_223_038_00466",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "おめでとう、アルビーナ。\nでも敵影がないとはいえ、まだ油断はできないわ",
		"voice_file": "VOICE_MAIN_152_038_00467",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ユミア",
		"romanized_name": "Yumia",
		"model_path_hash": "8553801663070209956",
		"text": "みんな、気を付けて！　おとりじゃなくて、\nこっちに向かってきてるのがいる！",
		"voice_file": "VOICE_MAIN_164_038_00468",
		"still_path_hash": "3603268135404135156",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "なっ！？　偽物だって気付かれたか！",
		"voice_file": "VOICE_MAIN_150_038_00469",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "なんて数……このままだと追いつかれるわ！",
		"voice_file": "VOICE_MAIN_152_038_00470",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "こんの！！",
		"voice_file": "VOICE_MAIN_150_038_00471",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "なんじゃいそりゃ！\n目ついてないのかあいつは！",
		"voice_file": "VOICE_MAIN_150_038_00472",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ベップ",
		"romanized_name": "Bepp",
		"model_path_hash": "3101416597918110218",
		"text": "姉様、危ない！　ぶつかる――！！",
		"voice_file": "VOICE_MAIN_151_038_00473",
		"still_path_hash": "5045460652135134961",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "きゃっ！！！",
		"voice_file": "VOICE_MAIN_152_038_00474",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ジョゼ",
		"romanized_name": "José",
		"model_path_hash": "0",
		"text": "な、なんだあ！？",
		"voice_file": "VOICE_MAIN_223_038_00475",
		"still_path_hash": "1488533364831425921",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "ここは俺たちに任せろ！",
		"voice_file": "VOICE_MAIN_115_038_00476",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "ウィルベル",
		"romanized_name": "Wilbell",
		"model_path_hash": "4415481844247416114",
		"text": "あたしたちが食い止めるわ！\nみんなは先に行きなさい！",
		"voice_file": "VOICE_MAIN_023_038_00477",
		"still_path_hash": "1953533162853626950",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "コルテスさんに、ウィルベルさん！？\nリアスたちも！　どうしてこんな所に！？",
		"voice_file": "VOICE_MAIN_150_038_00478",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "果ての大陸への到達は、あたしの夢でもあるから！\nやっぱり手助けしたくってさ！",
		"voice_file": "VOICE_MAIN_208_038_00479",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "ウィルベル",
		"romanized_name": "Wilbell",
		"model_path_hash": "4415481844247416114",
		"text": "あたしたち異邦人だって、力になりたいもの！\n最後までお供するわよ！",
		"voice_file": "VOICE_MAIN_023_038_00480",
		"still_path_hash": "1953533162853626950",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "でも、それじゃああなたたちが……！",
		"voice_file": "VOICE_MAIN_152_038_00481",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "いいから、早く行くんだ！\n大丈夫だ、必ず後から追いつく！",
		"voice_file": "VOICE_MAIN_115_038_00482",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "……分かった！　みんな、行こう！\n全速力で駆け抜けるよ！",
		"voice_file": "VOICE_MAIN_150_038_00483",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "……行ったか。\n大口を叩いたが、やれるよな",
		"voice_file": "VOICE_MAIN_115_038_00484",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ウィルベル",
		"romanized_name": "Wilbell",
		"model_path_hash": "4415481844247416114",
		"text": "この数……正直厳しいけど……\nでも、かっこつけたいじゃない",
		"voice_file": "VOICE_MAIN_023_038_00485",
		"still_path_hash": "1953533162853626950",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "そうだな。よし、みんな！　覚悟を決めろ！\nこの船が壊れるまで、何人たりともここを通すな！",
		"voice_file": "VOICE_MAIN_115_038_00486",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "0",
		"text": "先祖伝来の「船」を守る一族の戦士。\n王国から船を借り、レスナたちを追いかけてきた",
		"voice_file": "",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ウィルベル・フォル＝エルスリート",
		"romanized_name": "Wilbell Voll=ErsLied",
		"model_path_hash": "0",
		"text": "凄腕の魔法使い。\nコルテスたちと共に、レスナたちを追いかけてきた",
		"voice_file": "",
		"still_path_hash": "1953533162853626950",
		"speech_balloon_type_id": 780292254
	}
]