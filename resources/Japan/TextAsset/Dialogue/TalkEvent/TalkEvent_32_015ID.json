[
	{
		"id": 0,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "はあ、はあ……やっ……た……",
		"voice_file": "VOICE_MAIN_001_038_00596",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナ、大丈夫？",
		"voice_file": "VOICE_MAIN_002_038_00597",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん、大丈夫だよ。\nちょっと疲れて、力が抜けちゃっただけで……",
		"voice_file": "VOICE_MAIN_001_038_00598",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "レスナ。かっこよかった！\nよく言ってやったわ。すっきりした！",
		"voice_file": "VOICE_MAIN_150_038_00599",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レスナがした選択、間違ってないと思う。\nきっとみんなも、同じ気持ち。だから一緒に戦ったのよ",
		"voice_file": "VOICE_MAIN_002_038_00600",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "……ありがとう",
		"voice_file": "VOICE_MAIN_001_038_00601",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "こっちこそ、ありがとね。助けられちゃった",
		"voice_file": "VOICE_MAIN_048_038_00602",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "でも、信じてたわ。レスナなら、負けないって",
		"voice_file": "VOICE_MAIN_004_038_00603",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん……信じてくれて、ありがとう！",
		"voice_file": "VOICE_MAIN_001_038_00604",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "パルメ族の想いが受け入れられなかったのは残念だが、\n面白いものを見させてもらった",
		"voice_file": "VOICE_MAIN_227_038_00605",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "九偉人といえど、私たちはレスナちゃんの\nそばにいるって決めたんだ",
		"voice_file": "VOICE_MAIN_200_038_00606",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "その選択の先にある道を、我々も全力で支えよう。\n一人で背負わせたりはしない！",
		"voice_file": "VOICE_MAIN_155_038_00607",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "皆さん……ありがとうございます",
		"voice_file": "VOICE_MAIN_001_038_00608",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "？？？",
		"romanized_name": "???",
		"model_path_hash": "0",
		"text": "あ、いたー！　おーい！",
		"voice_file": "VOICE_MAIN_208_038_00609",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "え？　この声……",
		"voice_file": "VOICE_MAIN_150_038_00610",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "リアス！　他のみんなも……無事だったのね！",
		"voice_file": "VOICE_MAIN_002_038_00611",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "コルテス",
		"romanized_name": "Kortes",
		"model_path_hash": "6745194160365014115",
		"text": "ああ。さすがに船が割れた時はもうダメかと思ったが",
		"voice_file": "VOICE_MAIN_115_038_00612",
		"still_path_hash": "3797902451650633333",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "スレイ",
		"romanized_name": "Slade",
		"model_path_hash": "1119361770767559406",
		"text": "みんなも無事みたいでよかったよ",
		"voice_file": "VOICE_MAIN_209_038_00613",
		"still_path_hash": "5581277904703418049",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ウィルベル",
		"romanized_name": "Wilbell",
		"model_path_hash": "4415481844247416114",
		"text": "乗ってきた船がなくなっちゃったから、\n帰りは乗せてよね？",
		"voice_file": "VOICE_MAIN_023_038_00614",
		"still_path_hash": "1953533162853626950",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "何を言ってるんですか。\nもちろんですよ……本当に無事でよかった……！",
		"voice_file": "VOICE_MAIN_001_038_00615",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ヤンネ",
		"romanized_name": "Janne",
		"model_path_hash": "1819147851487138677",
		"text": "ええ……本当に、よかったわ……",
		"voice_file": "VOICE_MAIN_152_038_00616",
		"still_path_hash": "6181229795949782132",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "リアス",
		"romanized_name": "Rias",
		"model_path_hash": "8538886338969864227",
		"text": "それで、果ての大陸は見つかった！？\nここ……ではなさそう？",
		"voice_file": "VOICE_MAIN_208_038_00617",
		"still_path_hash": "1321279492992502345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "そうですよ皆様。安心するのは少し早いかと。\nまだ本懐を遂げられてはいないのです",
		"voice_file": "VOICE_MAIN_156_038_00618",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "でも、どうしよっか。案内人を倒しちゃったから、\n果ての大陸への道が分からなくなっちゃった",
		"voice_file": "VOICE_MAIN_048_038_00619",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "大丈夫。自分で見つけ出せばいいんだよ",
		"voice_file": "VOICE_MAIN_001_038_00620",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ここまでの道だって、\n誰かに案内されて来たわけじゃないんだから",
		"voice_file": "VOICE_MAIN_001_038_00621",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "そうだね。いつだって道は切り拓いて来たんだ。\n果ての大陸までの道だってへっちゃらだよね",
		"voice_file": "VOICE_MAIN_048_038_00622",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "その意気だ二人とも！\nなあに、心配する必要はないだろう",
		"voice_file": "VOICE_MAIN_155_038_00623",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "あの案内人の存在はアタシたちも知らなかったんだ。\n果ての大陸へたどり着くのに、あんなの必要じゃない",
		"voice_file": "VOICE_MAIN_153_038_00624",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "アウグストたちがレスナの甘さを矯正し、\nパルメ族の思想に染めあげるために配置したのだろう",
		"voice_file": "VOICE_MAIN_227_038_00625",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヘルト",
		"romanized_name": "Held",
		"model_path_hash": "1300312624310610838",
		"text": "まあ、思惑通りにはいかなかったようだが",
		"voice_file": "VOICE_MAIN_227_038_00626",
		"still_path_hash": "8474576122523799073",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "アルビーナ",
		"romanized_name": "Alvina",
		"model_path_hash": "2668606804942549205",
		"text": "だってさ。つまり、この先を探せば\nちゃんと見つけられるってことっしょ？",
		"voice_file": "VOICE_MAIN_150_038_00627",
		"still_path_hash": "8874763601186801212",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ええ。先を急ぎましょう。\n魔物たちが追いついてきちゃうかもしれないわ",
		"voice_file": "VOICE_MAIN_002_038_00628",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "うん、そうだね……行こう！",
		"voice_file": "VOICE_MAIN_001_038_00629",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	}
]