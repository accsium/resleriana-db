[
	{
		"id": 0,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "ふっ！",
		"voice_file": "VOICE_MAIN_004_038_00416",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "今ので最後だね。\nみんな、お疲れさま",
		"voice_file": "VOICE_MAIN_234_038_00417",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ロマン",
		"romanized_name": "Roman",
		"model_path_hash": "2044084852602675005",
		"text": "ケガしていないかい？",
		"voice_file": "VOICE_MAIN_049_038_00418",
		"still_path_hash": "2419706081160656678",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "大丈夫！　寒かったけどハンマーのおかげで\nあったまってきた！",
		"voice_file": "VOICE_MAIN_048_038_00419",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "ヨハナちゃんも、相変わらずの技の冴え！",
		"voice_file": "VOICE_MAIN_001_038_00420",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "これくらい当然よ、天才だからね！",
		"voice_file": "VOICE_MAIN_004_038_00421",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "待って、まだ気配がするわ！",
		"voice_file": "VOICE_MAIN_235_038_00422",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "こっち！　船に取り付いてるよ！",
		"voice_file": "VOICE_MAIN_234_038_00423",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "させない！！　レスナと、レスナの夢は私が守る！！",
		"voice_file": "VOICE_MAIN_235_038_00424",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "速っ……！",
		"voice_file": "VOICE_MAIN_048_038_00425",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "や、やるじゃない……ちょっと認めざるを得ないかも",
		"voice_file": "VOICE_MAIN_004_038_00426",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "クレオ",
		"romanized_name": "Cleo",
		"model_path_hash": "1405587059148187981",
		"text": "さすが「閃光」の異名を持つ冒険者。\nとんでもない切れ味ね！",
		"voice_file": "VOICE_MAIN_234_038_00427",
		"still_path_hash": "6779436863461642750",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "子を想う母は強いから",
		"voice_file": "VOICE_MAIN_235_038_00428",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "メーヴェ",
		"romanized_name": "Mowen",
		"model_path_hash": "8282561094361780418",
		"text": "それに……同じ空の下、どこかにいる愛するユリウスも\nきっと力を貸してくれている、そんな気がするの",
		"voice_file": "VOICE_MAIN_235_038_00429",
		"still_path_hash": "7917604627487944706",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "お母さんに、お父さん……友達に、先輩、\n王族の人まで、助けてくれる……",
		"voice_file": "VOICE_MAIN_001_038_00430",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "私って、恵まれてるなぁ。\n皆さん、改めて、感謝申し上げます！！",
		"voice_file": "VOICE_MAIN_001_038_00431",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ロマン",
		"romanized_name": "Roman",
		"model_path_hash": "2044084852602675005",
		"text": "何を言っているんだい。私たちをこうして引き合わせて\n繋ぎとめているのはレスナ、君じゃないか",
		"voice_file": "VOICE_MAIN_049_038_00432",
		"still_path_hash": "2419706081160656678",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "ヨハナ",
		"romanized_name": "Johanna",
		"model_path_hash": "377912885312431765",
		"text": "レスナが恵まれてるって言うなら、それはきっと\nここまでレスナがみんなに恵んだからよ",
		"voice_file": "VOICE_MAIN_004_038_00433",
		"still_path_hash": "6764252557264005345",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "……ほんとに、ありがとう！",
		"voice_file": "VOICE_MAIN_001_038_00434",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "みんなが手伝ってくれて、応援してくれてる。\nだから、あと少し……果ての大陸まで、絶対！",
		"voice_file": "VOICE_MAIN_001_038_00435",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "イザナ",
		"romanized_name": "Izana",
		"model_path_hash": "7061794453237574237",
		"text": "また魔物、上がって来るよ！\nハンマーで海の藻屑にしてあげる！",
		"voice_file": "VOICE_MAIN_048_038_00436",
		"still_path_hash": "7010833269667927555",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "レスナ",
		"romanized_name": "Resna",
		"model_path_hash": "6823802507187778884",
		"text": "――たどり着いてみせる！！",
		"voice_file": "VOICE_MAIN_001_038_00437",
		"still_path_hash": "2457375212832216718",
		"speech_balloon_type_id": 780292254
	}
]