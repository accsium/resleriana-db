[
	{
		"id": 0,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "ヘルト！　料理が終わるまで、そこで待っててね！",
		"voice_file": "VOICE_MAIN_002_037_01268",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 1,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "じゃ、みんな！　始めるわよ！",
		"voice_file": "VOICE_MAIN_002_037_01269",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 2,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "食材の準備は！？",
		"voice_file": "VOICE_MAIN_002_037_01270",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 3,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "できてるよー。\n商人もやってる僕が選んだんだ。どれもいい食材だよ",
		"voice_file": "VOICE_MAIN_154_037_01271",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 4,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "肉いっぱいじゃあ！　肉は見ているだけで元気になる",
		"voice_file": "VOICE_MAIN_228_037_01272",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 5,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "そうね、お肉は偉大だわ。で、調理道具は！？",
		"voice_file": "VOICE_MAIN_002_037_01273",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 6,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "は、はい！\nヤド姉と一緒に、良さそうなやつ持ってきたよ！",
		"voice_file": "VOICE_MAIN_200_037_01274",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 7,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "食器はどや！？",
		"voice_file": "VOICE_MAIN_002_037_01275",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 8,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "粋で洒落たやつ、揃えてきたよ！",
		"voice_file": "VOICE_MAIN_153_037_01276",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 9,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "レシピ！",
		"voice_file": "VOICE_MAIN_002_037_01277",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 10,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "ゴゥ兄様と共に仕上げました。\n再現率は９割２分といったところでしょうか",
		"voice_file": "VOICE_MAIN_156_037_01278",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 11,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "よし！　それじゃあ調理開始よ！",
		"voice_file": "VOICE_MAIN_002_037_01279",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 12,
		"localized_name": "みんな",
		"romanized_name": "",
		"model_path_hash": "0",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_002_037_01280_2",
		"still_path_hash": "0",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 13,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_228_037_01281",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 14,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_153_037_01282",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 15,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_154_037_01283",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 16,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_155_037_01284",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 17,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_156_037_01285",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 18,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_199_037_01286",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 19,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "おー！",
		"voice_file": "VOICE_MAIN_200_037_01287",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 20,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "キューン、鍋は重いだろう。\nお兄ちゃんに任せろ！",
		"voice_file": "VOICE_MAIN_155_037_01288",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 21,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "火、危険。\n私がやる",
		"voice_file": "VOICE_MAIN_199_037_01289",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 22,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "もう、ゴゥ兄もヤド姉も過保護だなぁ",
		"voice_file": "VOICE_MAIN_200_037_01290",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 23,
		"localized_name": "ゼロ",
		"romanized_name": "Zero",
		"model_path_hash": "6684953388752804572",
		"text": "肉の番は我に任せろ！\n……うまそうじゃなあ",
		"voice_file": "VOICE_MAIN_228_037_01291",
		"still_path_hash": "3236890542622906589",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 24,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "生だから、つまみ食いしちゃダメだよ……？",
		"voice_file": "VOICE_MAIN_200_037_01292",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 25,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "食材は、火の通りやすさを考えて切るんだ。\nだからこれは、あっちの食材より小さく……",
		"voice_file": "VOICE_MAIN_153_037_01293",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 26,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "うーん、こうかしら？\nあれ、小さくしすぎたかも？",
		"voice_file": "VOICE_MAIN_002_037_01294",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 27,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ははは！\n歪だが、味があっていいじゃないか！",
		"voice_file": "VOICE_MAIN_153_037_01295",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 28,
		"localized_name": "イェルカ",
		"romanized_name": "Jelka",
		"model_path_hash": "7989768780593008340",
		"text": "ってこらシトリン！　\n手が空いてるなら食材切るのを手伝っておくれ",
		"voice_file": "VOICE_MAIN_153_037_01296",
		"still_path_hash": "8715905000688515801",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 29,
		"localized_name": "シトリン",
		"romanized_name": "Citrine",
		"model_path_hash": "6017129171503572683",
		"text": "え～？　ヴァレリアがダメダメな分、\n僕の力が必要なのかな？",
		"voice_file": "VOICE_MAIN_154_037_01297",
		"still_path_hash": "924100309011770274",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 30,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "くっ……事実だけど\n言い方がいちいちムカつくわね……",
		"voice_file": "VOICE_MAIN_002_037_01298",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 31,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "今です、キューン！\nそこの調味料を入れてください",
		"voice_file": "VOICE_MAIN_156_037_01299",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 32,
		"localized_name": "キューン",
		"romanized_name": "Quinn",
		"model_path_hash": "913274709521753211",
		"text": "うん！　レシピ分量ぴったり、入れたよ！",
		"voice_file": "VOICE_MAIN_200_037_01300",
		"still_path_hash": "7374237645965483172",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 33,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "よろしい。次の工程は……",
		"voice_file": "VOICE_MAIN_156_037_01301",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 34,
		"localized_name": "ヤドヴィガ",
		"romanized_name": "Jadwiga",
		"model_path_hash": "2111970354351478659",
		"text": "１分煮込んだ後、次の食材を投入",
		"voice_file": "VOICE_MAIN_199_037_01302",
		"still_path_hash": "6170794110252514656",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 35,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "その通りです。この工程を乱すわけにはいきません",
		"voice_file": "VOICE_MAIN_156_037_01303",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 36,
		"localized_name": "ゴゥ",
		"romanized_name": "Gou",
		"model_path_hash": "5559160385657202980",
		"text": "妹たちよ、兄に何か手伝えることはあるか？",
		"voice_file": "VOICE_MAIN_155_037_01304",
		"still_path_hash": "2242265198409136417",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 37,
		"localized_name": "リーベ",
		"romanized_name": "Liebe",
		"model_path_hash": "281475164831455342",
		"text": "ではそこで１分数えていてください",
		"voice_file": "VOICE_MAIN_156_037_01305",
		"still_path_hash": "5075029600051949533",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 38,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "8455227271865371244",
		"text": "いきなり決めていきなり始めたけれど、\nなんかいい感じね",
		"voice_file": "VOICE_MAIN_002_037_01306",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	},
	{
		"id": 39,
		"localized_name": "ヴァレリア",
		"romanized_name": "Valeria",
		"model_path_hash": "0",
		"text": "（みんなで作る思い出の味……\n　これならきっと、今のヘルトにも……）",
		"voice_file": "VOICE_MAIN_002_037_01307",
		"still_path_hash": "6891392099494261238",
		"speech_balloon_type_id": 780292254
	}
]